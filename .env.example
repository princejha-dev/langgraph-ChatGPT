# LangGraph Chatbot Configuration
# Copy this file to .env and fill in your actual values

# ── Groq LLM ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Optional: defaults to llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# ── Tools ─────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Database ──────────────────────────────────────────────────
# Optional: defaults to <project_root>/data/chatbot.db
DATABASE_PATH=data/chatbot.db

# ── LangSmith Observability ───────────────────────────────────
# Set LANGCHAIN_TRACING_V2=true to enable tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=Agentic-Chatbot
